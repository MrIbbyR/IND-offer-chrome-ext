{
  "manifest_version": 3,
  "name": "NIQ TA Helper",
  "version": "1.9.1",
  "description": "Smartrecruiters TA helper for NIQ associates. Cost assist, Cntrl F Tagging & Boolean tagging and Offer automation",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://*.smartrecruiters.com/*",
    "https://*.greenhouse.io/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.smartrecruiters.com/*"],
      "js": ["sr-list-autoscroll.js", "salary-triage-core.js", "salary-triage-autorun.js", "keyword-triage-core.js", "keyword-triage-autorun.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
