{
  "manifest_version": 3,
  "name": "SR Offer Filler",
  "version": "1.1",
  "description": "Auto-fill SmartRecruiters offer fields from Excel",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://*.smartrecruiters.com/*",
    "https://*.greenhouse.io/*",
    "http://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png"
  }
}
